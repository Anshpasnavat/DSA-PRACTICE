#include <iostream>
#include <algorithm>
using namespace std;

bool twoSum(int arr[],int n,int target)
{
    int left = 0;
    int right = n- 1;

    while(left < right){
        if(target < arr[left]+arr[right]){
            right--;
        }else if(target > arr[left]+arr[right]){
            left++;
        }else{
            return true;
        }
    
    }
    return false;
}
int main() {

    int arr[] = {1, 2, 3,4,5,6,7};
    int n = sizeof(arr) / sizeof(int);
    int target = 10;
    cout << twoSum(arr, n, target);

}