class Solution {
public:
    // Same exact solution as 56. Merge Intervals (except no sorting needed!)
    vector<vector<int>> merge(vector<vector<int>>& intervals) {
        vector<vector<int>> ans (1, intervals[0]);
        
        for (int i = 1; i < intervals.size(); ++i) {
            bool isOverlappingWithCandidate = (max(intervals[i][0], ans.back()[0]) <= min(intervals[i][1], ans.back()[1]));
            if (isOverlappingWithCandidate) {
                ans.back()[0] = min(ans.back()[0], intervals[i][0]);
                ans.back()[1] = max(ans.back()[1], intervals[i][1]);
            } else {
                ans.push_back(intervals[i]);
            }
        }

        return ans;
    }
    vector<vector<int>> insert(vector<vector<int>>& intervals, vector<int>& newInterval) {
        int insertPosition = upper_bound(intervals.begin(), intervals.end(), newInterval) - intervals.begin();
        intervals.insert(intervals.begin() + insertPosition, newInterval);
        return merge(intervals);
    }
};