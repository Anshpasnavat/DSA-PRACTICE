class Solution {
public:
    bool isVowel(char c)
{
    return (c == 'a' || c == 'e' || c == 'i' || c == 'o' || c == 'u');
}
    int maxVowels(string s, int k) {
        int currVowels = 0;
        int maxVowels = 0;
        int n = s.length();
        for(int i = 0;i < k; i++){
            if(isVowel(s[i])){
                currVowels++;
            }
        }maxVowels = currVowels;
        for(int i = k;i<n;i++){
            if(isVowel(s[i-k])){
                currVowels--;
            }if(isVowel(s[i])){
                currVowels++;
            }
            maxVowels = max(currVowels, maxVowels);
        }
        return maxVowels;

    }
};