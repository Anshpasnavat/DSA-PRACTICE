class Solution {
  public:
    bool twoSum(vector<int>& arr, int target) {
        unordered_set<int> st;
        
        for(int i = 0; i < arr.size(); i++) {
            int complement = target - arr[i];
            
            if(st.find(complement) != st.end()) {
                return true;
            }
            
            st.insert(arr[i]);
        }
        
        return false;
    }
};