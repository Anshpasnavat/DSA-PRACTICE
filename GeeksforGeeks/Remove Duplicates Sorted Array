class Solution {
  public:
    vector<int> removeDuplicates(vector<int> &arr) {
        int n = arr.size();
        if(n == 0) return {};

        int i = 0;   // pointer for unique elements

        for(int j = 1; j < n; j++) {
            if(arr[j] != arr[i]) {
                i++;
                arr[i] = arr[j];
            }
        }

        vector<int> result;
        for(int k = 0; k <= i; k++) {
            result.push_back(arr[k]);
        }

        return result;
    }
};