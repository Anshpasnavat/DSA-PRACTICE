class Solution {
  public:
    void removeLoop(Node* head) {
        if(head == NULL || head->next == NULL)
            return;

        Node* slow = head;
        Node* fast = head;

        // Step 1: Detect loop
        while(fast != NULL && fast->next != NULL) {
            slow = slow->next;
            fast = fast->next->next;

            if(slow == fast)
                break;
        }

        // If no loop
        if(fast == NULL || fast->next == NULL)
            return;

        // Step 2: Find start of loop
        slow = head;

        // Special case: loop starts at head
        if(slow == fast) {
            while(fast->next != slow)
                fast = fast->next;
        }
        else {
            while(slow->next != fast->next) {
                slow = slow->next;
                fast = fast->next;
            }
        }

        // Step 3: Remove loop
        fast->next = NULL;
    }
};