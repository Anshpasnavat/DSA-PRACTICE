class Solution {
  public:
    int maxArea(vector<int> &arr) {
        // code here
        int i=0, j=arr.size()-1, ans=0;
        while(i<j) {
            ans = max(ans, min(arr[i], arr[j])*(j-i-1));
            if(arr[i] <= arr[j]) i++;
            else j--;
        }
        return ans;
    }
};